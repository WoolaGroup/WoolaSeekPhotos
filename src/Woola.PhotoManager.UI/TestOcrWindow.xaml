<Window x:Class="Woola.PhotoManager.UI.TestOcrWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Prueba OCR Agent" Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A1A">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <Border Style="{StaticResource WindowHeaderBorder}" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="📝 Prueba de Extracción de Texto" Style="{StaticResource WindowHeaderTitle}"/>
                <TextBlock Text="OCR y generación automática de tags desde texto detectado" Style="{StaticResource WindowHeaderSubtitle}"/>
            </StackPanel>
        </Border>

        <!-- Selección de imagen -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
            <Button x:Name="SelectImageBtn" Content="📁 Seleccionar Imagen" 
                    Click="SelectImageBtn_Click"
                    Background="#0078D4" Foreground="White"
                    Padding="15,8" BorderThickness="0" Cursor="Hand"/>
            <TextBlock x:Name="ImagePathText" Text="Ninguna imagen seleccionada" 
                       Foreground="#888888" VerticalAlignment="Center" Margin="15,0,0,0"/>
        </StackPanel>

        <!-- Contenido principal -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Imagen -->
            <Border Background="#252525" BorderBrush="#333333" BorderThickness="1" CornerRadius="8">
                <Image x:Name="PreviewImage" Stretch="Uniform" Margin="10"/>
            </Border>

            <!-- Resultados OCR -->
            <Border Grid.Column="1" Background="#252525" BorderBrush="#333333" 
                    BorderThickness="1" CornerRadius="8" Margin="10,0,0,0">
                <StackPanel Margin="10">
                    <TextBlock Text="📝 Texto Detectado" FontWeight="Bold" 
                               Foreground="White" Margin="0,0,0,10"/>

                    <ScrollViewer MaxHeight="300">
                        <TextBox x:Name="OcrText" TextWrapping="Wrap" 
                                 Background="#1A1A1A" Foreground="#CCCCCC"
                                 BorderThickness="0" IsReadOnly="True"
                                 FontSize="12" MinHeight="100"/>
                    </ScrollViewer>

                    <Separator Margin="0,15" Background="#333333"/>

                    <TextBlock Text="🏷️ Tags Generados" FontWeight="Bold" 
                               Foreground="White" Margin="0,0,0,10"/>

                    <ScrollViewer MaxHeight="200">
                        <ItemsControl x:Name="TagsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#333333" CornerRadius="4" Margin="0,3" Padding="8,5">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="●" Foreground="#0078D4" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Name}" Foreground="White" FontSize="11"/>
                                            <TextBlock Text=" " Foreground="White"/>
                                            <TextBlock Text="{Binding Confidence, StringFormat='/{0:P0}'}" 
                                                       Foreground="#888888" FontSize="10"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Estado -->
        <TextBlock x:Name="StatusText" Grid.Row="3" Text="Listo" 
                   Foreground="#888888" Margin="0,20,0,0"/>
    </Grid>
    </Window>