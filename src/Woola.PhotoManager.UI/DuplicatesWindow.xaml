<Window x:Class="Woola.PhotoManager.UI.DuplicatesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔄 Duplicados detectados" Width="780" Height="620"
        WindowStartupLocation="CenterOwner"
        Background="#0F0F0F" FontFamily="Segoe UI">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0" Text="🔄 Detección de Duplicados"
                   FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,16"/>

        <!-- Barra de progreso + botón analizar -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Grid.Column="0"
                           Text="Haz clic en 'Analizar' para buscar duplicados."
                           FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                <Button x:Name="AnalyzeBtn" Grid.Column="1"
                        Content="🔍 Analizar fotos" Width="140" Height="32"
                        Background="#0078D4" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="AnalyzeBtn_Click"/>
            </Grid>
            <ProgressBar x:Name="ProgressBar" Height="4"
                         Background="#252525" Foreground="#0078D4"
                         Value="0" Maximum="100" Visibility="Collapsed"/>
        </StackPanel>

        <!-- Lista de grupos -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="GroupsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#1A1A1A" CornerRadius="8"
                                Margin="0,0,0,12" Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Header del grupo -->
                                <TextBlock Grid.Row="0"
                                           Text="{Binding GroupLabel}"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="#555555"
                                           Margin="0,0,0,12"/>

                                <!-- Fotos en el grupo -->
                                <ItemsControl Grid.Row="1" ItemsSource="{Binding Photos}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#252525" CornerRadius="6"
                                                    Margin="0,0,12,0" Padding="8"
                                                    Width="170">
                                                <StackPanel>
                                                    <Border CornerRadius="4" ClipToBounds="True"
                                                            Height="110" Margin="0,0,0,8">
                                                        <Image Source="{Binding ThumbnailPath}"
                                                               Stretch="UniformToFill"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding FileName}"
                                                               FontSize="11" Foreground="White"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding DateInfo}"
                                                               FontSize="10" Foreground="#666666"
                                                               Margin="0,2,0,0"/>
                                                    <TextBlock Text="{Binding SizeInfo}"
                                                               FontSize="10" Foreground="#666666"/>
                                                    <Button Content="{Binding ActionLabel}"
                                                            Tag="{Binding}"
                                                            Margin="0,8,0,0" Height="26"
                                                            Background="{Binding ActionBg}"
                                                            Foreground="White" BorderThickness="0"
                                                            Cursor="Hand"
                                                            Click="PhotoAction_Click"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Botón ignorar grupo -->
                                <Button Grid.Row="2"
                                        Content="↩ Ignorar este grupo"
                                        Tag="{Binding}"
                                        Margin="0,12,0,0" Height="28"
                                        HorizontalAlignment="Left"
                                        Background="#333333" Foreground="#888888"
                                        BorderThickness="0" Cursor="Hand"
                                        Click="IgnoreGroup_Click"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer -->
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="SummaryText"
                       FontSize="11" Foreground="#666666" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="Cerrar" Width="90" Height="32"
                    Background="#252525" Foreground="#888888"
                    BorderBrush="#333333" BorderThickness="1"
                    Cursor="Hand" Click="CloseBtn_Click"/>
        </Grid>
    </Grid>
</Window>
