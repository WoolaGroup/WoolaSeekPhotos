<Window x:Class="Woola.PhotoManager.UI.AlbumWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Álbumes" Width="1000" Height="660"
        WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ PANEL IZQUIERDO: lista de álbumes ══════════════════════════════ -->
        <Border Background="{StaticResource BrushBgSurface}"
                BorderBrush="{StaticResource BrushBorderSubtle}" BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Header -->
                <Border DockPanel.Dock="Top" Padding="16,14"
                        Background="{StaticResource BrushBgDeep}"
                        BorderBrush="{StaticResource BrushBorderSubtle}" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="Álbumes" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushTextPrimary}" Margin="0,0,0,10"/>

                        <!-- Botón crear (modo normal) -->
                        <Button x:Name="CreateAlbumBtn" Click="CreateAlbumBtn_Click"
                                Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" FontSize="14" Margin="0,0,7,0" FontWeight="Bold"/>
                                <TextBlock Text="Nuevo álbum"/>
                            </StackPanel>
                        </Button>

                        <!-- Formulario inline (oculto hasta que se pulse Nuevo álbum) -->
                        <StackPanel x:Name="NewAlbumForm" Visibility="Collapsed" Margin="0,6,0,0">
                            <TextBox x:Name="NewAlbumNameBox"
                                     Height="34" MaxLength="80"
                                     VerticalContentAlignment="Center"
                                     KeyDown="NewAlbumNameBox_KeyDown"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button x:Name="ConfirmCreateBtn" Content="Crear"
                                        Style="{StaticResource PrimaryButton}"
                                        Click="ConfirmCreateBtn_Click"
                                        Padding="0,6" Width="104"/>
                                <Button Content="Cancelar"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="CancelCreateBtn_Click"
                                        Padding="0,6" Width="76"
                                        Margin="6,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Lista de álbumes -->
                <ListBox x:Name="AlbumListBox"
                         SelectionChanged="AlbumListBox_SelectionChanged"
                         Background="Transparent" BorderThickness="0"
                         Padding="8" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding"          Value="0"/>
                            <Setter Property="Margin"           Value="0,2"/>
                            <Setter Property="Background"       Value="Transparent"/>
                            <Setter Property="BorderThickness"  Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="12,10" Cursor="Hand">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{StaticResource BrushBgSelected}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{StaticResource BrushBgCard}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource BrushTextPrimary}"/>
                                    <TextBlock Text="{Binding PhotoCount, StringFormat='{}{0} fotos'}"
                                               FontSize="11" Foreground="{StaticResource BrushTextMuted}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="✕" Style="{StaticResource DangerButton}"
                                        Padding="6,4" FontSize="11"
                                        Tag="{Binding Id}"
                                        Click="DeleteAlbumBtn_Click"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ══ PANEL DERECHO: contenido del álbum ════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- header álbum -->
                <RowDefinition Height="*"/>     <!-- fotos en álbum -->
                <RowDefinition Height="5"/>     <!-- separador visual -->
                <RowDefinition Height="200"/>   <!-- selector: agregar fotos -->
                <RowDefinition Height="Auto"/>  <!-- status bar -->
            </Grid.RowDefinitions>

            <!-- Header álbum seleccionado -->
            <Border Grid.Row="0"
                    Background="{StaticResource BrushBgSurface}"
                    BorderBrush="{StaticResource BrushBorderSubtle}"
                    BorderThickness="0,0,0,1"
                    Padding="20,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="AlbumNameTxt" Text="Selecciona un álbum"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushTextPrimary}"/>
                        <TextBlock x:Name="AlbumCountTxt" FontSize="11"
                                   Foreground="{StaticResource BrushTextMuted}" Margin="0,3,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" x:Name="ExportZipBtn"
                            Content="Exportar ZIP"
                            Click="ExportZipBtn_Click"
                            Style="{StaticResource SecondaryButton}"
                            Padding="12,6" FontSize="11"
                            VerticalAlignment="Center"
                            ToolTip="Exportar fotos del álbum como archivo ZIP"/>
                </Grid>
            </Border>

            <!-- Fotos del álbum seleccionado -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          Background="{StaticResource BrushBgDeep}">
                <WrapPanel x:Name="AlbumPhotosPanel" Margin="12"/>
            </ScrollViewer>

            <!-- Separador visual -->
            <Border Grid.Row="2" Background="{StaticResource BrushBorderSubtle}"/>

            <!-- Sección: agregar fotos recientes -->
            <Border Grid.Row="3" Background="{StaticResource BrushBgSurface}">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="16,8"
                            BorderBrush="{StaticResource BrushBorderSubtle}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Agregar fotos recientes al álbum"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text=" · haz clic en una foto para añadirla"
                                       FontSize="10" Foreground="{StaticResource BrushTextMuted}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <WrapPanel x:Name="AllPhotosPanel" Margin="8,6" Orientation="Horizontal"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Status bar -->
            <Border Grid.Row="4"
                    Background="{StaticResource BrushBgDeep}"
                    BorderBrush="{StaticResource BrushBorderSubtle}"
                    BorderThickness="0,1,0,0"
                    Padding="16,7">
                <TextBlock x:Name="StatusTxt" FontSize="11"
                           Foreground="{StaticResource BrushTextMuted}"/>
            </Border>
        </Grid>
    </Grid>
</Window>
