<Window x:Class="Woola.PhotoManager.UI.AlbumWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📁 Álbumes" Width="1000" Height="660"
        WindowStartupLocation="CenterOwner"
        Background="#0F0F0F" FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <SolidColorBrush x:Key="PanelBg"    Color="#1A1A1A"/>
        <SolidColorBrush x:Key="CardBg"     Color="#252525"/>
        <SolidColorBrush x:Key="BorderClr"  Color="#333333"/>
        <SolidColorBrush x:Key="PrimaryClr" Color="#0078D4"/>
        <SolidColorBrush x:Key="TextPri"    Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSec"    Color="#888888"/>

        <Style TargetType="Button">
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="Padding"          Value="12,7"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#3A1A1A"/>
            <Setter Property="Foreground" Value="#FF6B6B"/>
        </Style>
        <Style x:Key="SecBtn" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="{StaticResource TextSec}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ PANEL IZQUIERDO: lista de álbumes ══════════════════════════════ -->
        <Border Background="{StaticResource PanelBg}"
                BorderBrush="{StaticResource BorderClr}" BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Header -->
                <Border DockPanel.Dock="Top" Padding="16,14"
                        BorderBrush="{StaticResource BorderClr}" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="📁 Álbumes" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextPri}" Margin="0,0,0,10"/>
                        <Button x:Name="CreateAlbumBtn" Click="CreateAlbumBtn_Click"
                                Background="{StaticResource PrimaryClr}" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="＋" FontSize="15" Margin="0,0,8,0" FontWeight="Bold"/>
                                <TextBlock Text="Nuevo álbum"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Lista de álbumes -->
                <ListBox x:Name="AlbumListBox"
                         SelectionChanged="AlbumListBox_SelectionChanged"
                         Background="Transparent" BorderThickness="0"
                         Padding="8" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding"          Value="0"/>
                            <Setter Property="Margin"           Value="0,2"/>
                            <Setter Property="Background"       Value="Transparent"/>
                            <Setter Property="BorderThickness"  Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="12,10" Cursor="Hand">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#1E2D3D"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#232323"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPri}"/>
                                    <TextBlock Text="{Binding PhotoCount, StringFormat='{}{0} fotos'}"
                                               FontSize="11" Foreground="{StaticResource TextSec}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="🗑" Style="{StaticResource DangerBtn}"
                                        Padding="6,4" FontSize="13"
                                        Tag="{Binding Id}"
                                        Click="DeleteAlbumBtn_Click"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ══ PANEL DERECHO: contenido del álbum ════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- header álbum -->
                <RowDefinition Height="*"/>     <!-- fotos en álbum -->
                <RowDefinition Height="8"/>     <!-- separador visual -->
                <RowDefinition Height="200"/>   <!-- selector: agregar fotos -->
                <RowDefinition Height="Auto"/>  <!-- status bar -->
            </Grid.RowDefinitions>

            <!-- Header álbum seleccionado -->
            <Border Grid.Row="0" Background="#141414" Padding="20,14"
                    BorderBrush="{StaticResource BorderClr}" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock x:Name="AlbumNameTxt" Text="Selecciona un álbum"
                               FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPri}"/>
                    <TextBlock x:Name="AlbumCountTxt" FontSize="11"
                               Foreground="{StaticResource TextSec}" Margin="0,3,0,0"/>
                </StackPanel>
            </Border>

            <!-- Fotos del álbum seleccionado -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <WrapPanel x:Name="AlbumPhotosPanel" Margin="12"/>
            </ScrollViewer>

            <!-- Separador: "Agregar fotos" -->
            <Border Grid.Row="2" Background="#252525"/>
            <Border Grid.Row="3" Background="#111111">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="16,8"
                            BorderBrush="{StaticResource BorderClr}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="＋ Agregar fotos recientes al álbum"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSec}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text=" (haz clic en una foto para añadirla)"
                                       FontSize="10" Foreground="#555" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <WrapPanel x:Name="AllPhotosPanel" Margin="8,6" Orientation="Horizontal"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Status bar -->
            <Border Grid.Row="4" Background="#0A0A0A" Padding="16,7"
                    BorderBrush="{StaticResource BorderClr}" BorderThickness="0,1,0,0">
                <TextBlock x:Name="StatusTxt" FontSize="11"
                           Foreground="{StaticResource TextSec}"/>
            </Border>
        </Grid>
    </Grid>
</Window>
