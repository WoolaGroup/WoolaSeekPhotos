<Window x:Class="Woola.PhotoManager.UI.SimilarPhotosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔍 Fotos similares" Width="700" Height="520"
        WindowStartupLocation="CenterOwner"
        Background="#0F0F0F" FontFamily="Segoe UI">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0" x:Name="TitleText"
                   Text="🔍 Fotos similares"
                   FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>

        <!-- Subtítulo -->
        <TextBlock Grid.Row="1" x:Name="StatusText"
                   Text="Buscando..." FontSize="12" Foreground="#888888"
                   Margin="0,0,0,16"/>

        <!-- Grid de fotos -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="PhotosGrid">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#1A1A1A" CornerRadius="8"
                                Margin="0,0,10,10" Padding="8"
                                Width="150" Cursor="Hand"
                                MouseLeftButtonDown="Photo_DoubleClick">
                            <StackPanel>
                                <Border CornerRadius="6" ClipToBounds="True"
                                        Height="120" Margin="0,0,0,8">
                                    <Image Source="{Binding ThumbnailPath}" Stretch="UniformToFill"/>
                                </Border>
                                <!-- Barra de similitud -->
                                <Grid Margin="0,0,0,4">
                                    <ProgressBar Height="3"
                                                 Value="{Binding SimilarityPercent, Mode=OneWay}"
                                                 Maximum="100"
                                                 Background="#333333" Foreground="#0078D4"/>
                                </Grid>
                                <TextBlock Text="{Binding SimilarityLabel}"
                                           FontSize="12" FontWeight="Bold"
                                           Foreground="#0078D4"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding FileName}"
                                           FontSize="10" Foreground="#888888"
                                           TextTrimming="CharacterEllipsis"
                                           TextAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer -->
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Doble clic para abrir la foto en el explorador"
                       FontSize="10" Foreground="#444444" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="Cerrar" Width="90" Height="32"
                    Background="#252525" Foreground="#888888"
                    BorderBrush="#333333" BorderThickness="1"
                    Cursor="Hand" Click="CloseBtn_Click"/>
        </Grid>
    </Grid>
</Window>
