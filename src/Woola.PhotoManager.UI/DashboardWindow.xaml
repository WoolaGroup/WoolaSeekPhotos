<Window x:Class="Woola.PhotoManager.UI.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📊 Dashboard" Width="820" Height="680"
        WindowStartupLocation="CenterOwner"
        Background="#0F0F0F" FontFamily="Segoe UI">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,28">

            <!-- Título -->
            <TextBlock Text="📊 Dashboard" FontSize="22" FontWeight="Bold"
                       Foreground="White" Margin="0,0,0,20"/>

            <!-- ══ Tarjetas de resumen ═══════════════════════════════════════ -->
            <UniformGrid Columns="4" Margin="0,0,0,20">
                <Border Background="#1A1A1A" CornerRadius="8" Padding="16" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="📸  FOTOS"  FontSize="10" Foreground="#666" FontWeight="Bold"/>
                        <TextBlock x:Name="TotalPhotosText"  FontSize="30" FontWeight="Bold"
                                   Foreground="#0078D4" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="#1A1A1A" CornerRadius="8" Padding="16" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="🏷️  TAGS"   FontSize="10" Foreground="#666" FontWeight="Bold"/>
                        <TextBlock x:Name="TotalTagsText"    FontSize="30" FontWeight="Bold"
                                   Foreground="#0078D4" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="#1A1A1A" CornerRadius="8" Padding="16" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="👤  ROSTROS" FontSize="10" Foreground="#666" FontWeight="Bold"/>
                        <TextBlock x:Name="TotalFacesText"   FontSize="30" FontWeight="Bold"
                                   Foreground="#0078D4" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="#1A1A1A" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="📁  ÁLBUMES" FontSize="10" Foreground="#666" FontWeight="Bold"/>
                        <TextBlock x:Name="TotalAlbumsText"  FontSize="30" FontWeight="Bold"
                                   Foreground="#0078D4" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ══ Fila central: Top Tags + Fotos por mes ═══════════════════ -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Top Tags -->
                <Border Grid.Column="0" Background="#1A1A1A" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="🏷️  TAGS MÁS USADOS" FontSize="10" Foreground="#666"
                                   FontWeight="Bold" Margin="0,0,0,12"/>
                        <ItemsControl x:Name="TopTagsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="44"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid>
                                            <!-- Barra de progreso -->
                                            <ProgressBar Value="{Binding Count, Mode=OneWay}" Maximum="{Binding MaxCount, Mode=OneWay}"
                                                         Height="20" Background="#2A2A2A"
                                                         Foreground="#0078D4" BorderThickness="0"/>
                                            <TextBlock Text="{Binding Name}" FontSize="10" Foreground="White"
                                                       VerticalAlignment="Center" Margin="6,0,0,0"/>
                                        </Grid>
                                        <TextBlock Grid.Column="1" Text="{Binding Count}"
                                                   FontSize="10" Foreground="#888"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Fotos por mes -->
                <Border Grid.Column="2" Background="#1A1A1A" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="📅  FOTOS POR MES" FontSize="10" Foreground="#666"
                                   FontWeight="Bold" Margin="0,0,0,12"/>
                        <ItemsControl x:Name="MonthList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="75"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Month}" FontSize="10"
                                                   Foreground="#888" VerticalAlignment="Center"/>
                                        <ProgressBar Grid.Column="1"
                                                     Value="{Binding Count, Mode=OneWay}"
                                                     Maximum="{Binding MaxCount, Mode=OneWay}"
                                                     Height="16" Background="#2A2A2A"
                                                     Foreground="#17A589" BorderThickness="0"
                                                     Margin="6,0"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Count}"
                                                   FontSize="10" Foreground="#888"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══ Tags por agente ═══════════════════════════════════════════ -->
            <Border Background="#1A1A1A" CornerRadius="8" Padding="16">
                <StackPanel>
                    <TextBlock Text="🤖  TAGS POR AGENTE" FontSize="10" Foreground="#666"
                               FontWeight="Bold" Margin="0,0,0,12"/>
                    <ItemsControl x:Name="SourceList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Source}" FontSize="11"
                                               Foreground="#CCCCCC" VerticalAlignment="Center"/>
                                    <ProgressBar Grid.Column="1"
                                                 Value="{Binding Count, Mode=OneWay}"
                                                 Maximum="{Binding MaxCount, Mode=OneWay}"
                                                 Height="18" Background="#2A2A2A"
                                                 Foreground="#7D3C98" BorderThickness="0"
                                                 Margin="6,0"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Count}"
                                               FontSize="11" Foreground="#888"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Pie: fotos indexadas hoy -->
            <TextBlock x:Name="FooterText" FontSize="11" Foreground="#555"
                       HorizontalAlignment="Right" Margin="0,14,0,0"/>
        </StackPanel>
    </ScrollViewer>
</Window>
