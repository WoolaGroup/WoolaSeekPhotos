<Window x:Class="Woola.PhotoManager.UI.CloudImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Importar desde Google Drive"
        Width="920" Height="680"
        MinWidth="720" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrushBgDeep}"
        FontFamily="Segoe UI Variable Display, Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- ROW 0: Header -->
            <RowDefinition Height="56"/>    <!-- ROW 1: Drive path + Scan button -->
            <RowDefinition Height="40"/>    <!-- ROW 2: Filter + Select all + count -->
            <RowDefinition Height="*"/>     <!-- ROW 3: ListView de fotos -->
            <RowDefinition Height="64"/>    <!-- ROW 4: Status + botones de acción -->
        </Grid.RowDefinitions>

        <!-- ROW 0 — Header ─────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Style="{StaticResource WindowHeaderBorder}"
                Margin="0,0,0,0">
            <StackPanel>
                <TextBlock Text="Importar desde Google Drive"
                           Style="{StaticResource WindowHeaderTitle}"/>
                <TextBlock Text="Detecta las fotos en tu carpeta local de Google Drive, selecciónalas e impórtalas a Woola"
                           Style="{StaticResource WindowHeaderSubtitle}"/>
            </StackPanel>
        </Border>

        <!-- ROW 1 — Ruta de Google Drive ───────────────────────────────── -->
        <Border Grid.Row="1"
                Background="{StaticResource BrushBgSurface}"
                BorderBrush="{StaticResource BrushBorderSubtle}"
                BorderThickness="0,0,0,1"
                Padding="16,0">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Carpeta:"
                           FontSize="12"
                           Foreground="{StaticResource BrushTextSecondary}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>

                <TextBlock Grid.Column="1"
                           x:Name="DrivePathText"
                           Text="No detectado"
                           FontSize="12"
                           Foreground="{StaticResource BrushTextMuted}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>

                <Button Grid.Column="2"
                        Content="Cambiar"
                        Style="{StaticResource SecondaryButton}"
                        Padding="12,5" Margin="10,0,8,0"
                        Click="ChangePathBtn_Click"/>

                <Button Grid.Column="3"
                        x:Name="ScanBtn"
                        Content="Escanear ▶"
                        Style="{StaticResource PrimaryButton}"
                        Padding="14,5"
                        Click="ScanBtn_Click"/>
            </Grid>
        </Border>

        <!-- ROW 2 — Filtro + Selección ─────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{StaticResource BrushBgDeep}"
                BorderBrush="{StaticResource BrushBorderSubtle}"
                BorderThickness="0,0,0,1"
                Padding="16,0">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         x:Name="FilterBox"
                         Height="28"
                         Padding="8,0"
                         VerticalContentAlignment="Center"
                         FontSize="12"
                         TextChanged="FilterBox_TextChanged">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush TileMode="None" Stretch="None"
                                                         AlignmentX="Left" AlignmentY="Center">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="  Filtrar por nombre..."
                                                               Foreground="#3D4F68"
                                                               FontSize="12"
                                                               Background="#1A2235"
                                                               Padding="8,5"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <Button Grid.Column="1"
                        Content="Seleccionar todo"
                        Style="{StaticResource GhostButton}"
                        Padding="12,5" Margin="8,0,4,0"
                        Click="SelectAllBtn_Click"/>

                <TextBlock Grid.Column="2"
                           x:Name="SelectionCountText"
                           Text="0 seleccionadas"
                           FontSize="12"
                           Foreground="{StaticResource BrushTextMuted}"
                           VerticalAlignment="Center"
                           Margin="4,0,0,0"/>
            </Grid>
        </Border>

        <!-- ROW 3 — Lista de fotos ──────────────────────────────────────── -->
        <Border Grid.Row="3"
                Background="{StaticResource BrushBgDeep}">
            <Grid>
                <!-- Estado vacío mientras no se escanea -->
                <StackPanel x:Name="EmptyState"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="☁"
                               FontSize="48"
                               Foreground="{StaticResource BrushBorderDefault}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>
                    <TextBlock Text="Haz clic en «Escanear» para buscar fotos"
                               FontSize="14"
                               Foreground="{StaticResource BrushTextMuted}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Lista con resultados -->
                <ListView x:Name="PhotoListView"
                          Visibility="Collapsed"
                          Background="{StaticResource BrushBgDeep}"
                          BorderThickness="0"
                          Foreground="{StaticResource BrushTextPrimary}"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="34">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  VerticalAlignment="Center"
                                                  Checked="PhotoCheckBox_Changed"
                                                  Unchecked="PhotoCheckBox_Changed"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="Archivo" Width="280">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FileName}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource BrushTextPrimary}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="Carpeta" Width="240">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FolderPath}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource BrushTextSecondary}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="Tamaño" Width="90">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SizeDisplay}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource BrushTextMuted}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="Modificado" Width="140">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding LastModifiedDisplay}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource BrushTextMuted}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="Estado" Width="100">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding StatusDisplay}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource BrushTextMuted}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>

                    <!-- Estilo de fila para hover -->
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="2,3"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource BrushBgCard}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource BrushBgSelected}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>
        </Border>

        <!-- ROW 4 — Status bar + botones ───────────────────────────────── -->
        <Border Grid.Row="4"
                Background="{StaticResource BrushBgSurface}"
                BorderBrush="{StaticResource BrushBorderSubtle}"
                BorderThickness="0,1,0,0"
                Padding="16,0">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Estado + progreso -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText"
                               Text="Listo"
                               FontSize="12"
                               Foreground="{StaticResource BrushTextMuted}"/>
                    <ProgressBar x:Name="ImportProgress"
                                 Height="3"
                                 Visibility="Collapsed"
                                 Margin="0,5,40,0"/>
                </StackPanel>

                <!-- Botones -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="CancelImportBtn"
                            Content="Cancelar"
                            Style="{StaticResource SecondaryButton}"
                            Padding="14,6"
                            Click="CancelImportBtn_Click"/>
                    <Button x:Name="ImportBtn"
                            Content="Importar seleccionadas"
                            Style="{StaticResource PrimaryButton}"
                            Padding="16,6"
                            Margin="10,0,0,0"
                            IsEnabled="False"
                            Click="ImportBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
