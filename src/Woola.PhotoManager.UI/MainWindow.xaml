<Window x:Class="Woola.PhotoManager.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Woola.PhotoManager.UI.Converters"
        xmlns:controls="clr-namespace:Woola.PhotoManager.UI.Controls"
        Title="Woola Smart Photo Manager"
        Height="900" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#0F0F0F"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Colores -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#0078D4"/>
        <SolidColorBrush x:Key="DarkBg" Color="#0F0F0F"/>
        <SolidColorBrush x:Key="PanelBg" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="CardBg" Color="#252525"/>
        <SolidColorBrush x:Key="BorderColor" Color="#333333"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#888888"/>
        <SolidColorBrush x:Key="TextMuted" Color="#555555"/>

        <!-- Converters -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolConverter x:Key="InvBool"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
        <conv:BitmapImageConverter x:Key="BitmapImageConv"/>

        <!-- Botón primario -->
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#333333"/>
                    <Setter Property="Foreground" Value="#666666"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Botón secundario -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2A2A"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Tarjeta de foto -->
        <Style TargetType="Border" x:Key="PhotoCard">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2D2D2D"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR IZQUIERDO -->
        <Border Grid.Column="0" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">
                    <!-- Logo -->
                    <Border Height="60" Margin="0,20,0,30">
                        <TextBlock Text="📸 Woola" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryColor}"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- Botones principales -->
                    <Button x:Name="SelectFolderBtn"
                            Command="{Binding StartIndexingCommand}"
                            IsEnabled="{Binding IsIndexing, Converter={StaticResource InvBool}}"
                            Background="{StaticResource PrimaryColor}" Margin="0,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📁" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Seleccionar Carpeta"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="ReprocessTagsBtn" Click="ReprocessTagsBtn_Click"
                            Style="{StaticResource SecondaryButton}" Margin="0,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏷️" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Reprocesar Tags"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="StopBtn"
                            Command="{Binding StopIndexingCommand}"
                            IsEnabled="{Binding IsIndexing}"
                            Style="{StaticResource SecondaryButton}" Margin="0,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⏹️" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Detener Indexación"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="PresentationBtn" Click="PresentationBtn_Click"
                            Style="{StaticResource SecondaryButton}" Margin="0,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎬" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Modo Presentación"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="TestVisionBtn" Click="TestVisionBtn_Click"
                            Style="{StaticResource SecondaryButton}" Margin="0,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👁️" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Probar VisionAgent"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="TestOcrBtn" Click="TestOcrBtn_Click"
                            Style="{StaticResource SecondaryButton}" Margin="0,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📝" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Probar OCR Agent"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="FaceManagementBtn" Click="FaceManagementBtn_Click"
                            Style="{StaticResource SecondaryButton}" Margin="0,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👤" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Gestionar Rostros"/>
                        </StackPanel>
                    </Button>

                    <Separator Margin="0,20" Background="{StaticResource BorderColor}"/>

                    <!-- Total Fotos -->
                    <Border Background="{StaticResource CardBg}" CornerRadius="8" Padding="12" Margin="0,5">
                        <StackPanel>
                            <TextBlock Text="📸 Total Fotos" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                            <TextBlock Text="{Binding PhotoCountText}" FontSize="24"
                                       FontWeight="Bold" Foreground="{StaticResource PrimaryColor}"/>
                        </StackPanel>
                    </Border>

                    <Separator Margin="0,20" Background="{StaticResource BorderColor}"/>

                    <!-- Tags populares -->
                    <TextBlock Text="TAGS POPULARES" FontSize="11"
                               Foreground="{StaticResource TextMuted}"
                               Margin="0,0,0,10"/>

                    <ItemsControl ItemsSource="{Binding Tags}" Margin="0,0,0,10">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Name}"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="0,0,8,8"
                                        Padding="10,5"
                                        FontSize="11"
                                        Command="{Binding DataContext.FilterByTagCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding Name}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Separator Margin="0,20" Background="{StaticResource BorderColor}"/>

                    <!-- Filtros rápidos -->
                    <TextBlock Text="FILTROS RÁPIDOS" FontSize="11"
                               Foreground="{StaticResource TextMuted}"
                               Margin="0,0,0,10"/>

                    <Button Content="📷 Todas las fotos"
                            Command="{Binding FilterAllCommand}"
                            Style="{StaticResource SecondaryButton}" Margin="0,5"/>

                    <Button Content="🕐 Últimos 30 días"
                            Command="{Binding FilterRecentCommand}"
                            Style="{StaticResource SecondaryButton}" Margin="0,5"/>

                    <!-- G1: ÁLBUMES ──────────────────────────── -->
                    <Separator Margin="0,20" Background="{StaticResource BorderColor}"/>
                    <TextBlock Text="ÁLBUMES" FontSize="11"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>

                    <Button x:Name="AlbumsBtn" Click="AlbumsBtn_Click"
                            Style="{StaticResource SecondaryButton}" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📁" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Gestionar álbumes"/>
                        </StackPanel>
                    </Button>

                    <ItemsControl ItemsSource="{Binding SidebarAlbums}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource SecondaryButton}"
                                        Margin="0,2" HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Command="{Binding DataContext.FilterByAlbumCommand,
                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📂" FontSize="12" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding Name}" FontSize="11" TextTrimming="CharacterEllipsis" MaxWidth="140"/>
                                        <TextBlock Text="{Binding PhotoCount, StringFormat=' ({0})'}"
                                                   FontSize="10" Foreground="{StaticResource TextMuted}" Margin="2,0,0,0"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- G3: EVENTOS ──────────────────────────── -->
                    <Separator Margin="0,20" Background="{StaticResource BorderColor}"/>
                    <TextBlock Text="EVENTOS" FontSize="11"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>

                    <ItemsControl ItemsSource="{Binding Events}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource SecondaryButton}"
                                        Margin="0,2" HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Command="{Binding DataContext.FilterByEventCommand,
                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📅" FontSize="12" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding DisplayName}" FontSize="11"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="130"/>
                                        <TextBlock Text="{Binding CountLabel}" FontSize="10"
                                                   Foreground="{StaticResource TextMuted}" Margin="4,0,0,0"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- G5: DASHBOARD ────────────────────────── -->
                    <Separator Margin="0,20" Background="{StaticResource BorderColor}"/>
                    <Button x:Name="DashboardBtn" Click="DashboardBtn_Click"
                            Style="{StaticResource SecondaryButton}" Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Dashboard"/>
                        </StackPanel>
                    </Button>

                    <!-- IMP-005/010: HERRAMIENTAS ─────────────── -->
                    <Button x:Name="DuplicatesBtn" Click="DuplicatesBtn_Click"
                            Style="{StaticResource SecondaryButton}" Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Duplicados"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="SettingsBtn" Click="SettingsBtn_Click"
                            Style="{StaticResource SecondaryButton}" Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙️" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Configuración"/>
                        </StackPanel>
                    </Button>

                    <!-- Carpeta seleccionada -->
                    <Separator Margin="0,20" Background="{StaticResource BorderColor}"/>
                    <TextBlock Text="CARPETA" FontSize="11"
                               Foreground="{StaticResource TextMuted}"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding FolderPathText}"
                               FontSize="11" Foreground="{StaticResource TextSecondary}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- PANEL PRINCIPAL CENTRO -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Barra de búsqueda híbrida -->
            <Border Grid.Row="0" Background="{StaticResource DarkBg}" Padding="20,15">
                <TextBox x:Name="SearchBox"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="14"
                         Padding="15,12"
                         Background="{StaticResource CardBg}"
                         Foreground="{StaticResource TextPrimary}"
                         BorderThickness="0"
                         CaretBrush="{StaticResource PrimaryColor}">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding HybridSearchCommand}"/>
                    </TextBox.InputBindings>
                    <TextBox.Resources>
                        <VisualBrush x:Key="Hint" TileMode="None" Stretch="None" AlignmentX="Left">
                            <VisualBrush.Visual>
                                <TextBlock Text="🔍 Buscar... (Enter para búsqueda híbrida)"
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="13" VerticalAlignment="Center"/>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </TextBox.Resources>
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Background" Value="{StaticResource CardBg}"/>
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background" Value="{StaticResource Hint}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </Border>

            <!-- Indicadores: modo híbrido + chips de filtro activo -->
            <StackPanel Grid.Row="1" Margin="20,0,20,0">
                <Border Visibility="{Binding IsHybridModeVisible, Converter={StaticResource BoolToVis}}"
                        Background="#0078D4" Padding="8,4" CornerRadius="4"
                        Margin="0,0,0,6" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍" Foreground="White" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding HybridModeLabel}" Foreground="White" FontSize="11"/>
                        <Button Content="✖"
                                Command="{Binding ClearSearchCommand}"
                                Background="Transparent" BorderThickness="0"
                                Foreground="White" Margin="10,0,0,0" Cursor="Hand"/>
                    </StackPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding ActiveFilters}" Margin="0,0,0,6">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1E2D3D" CornerRadius="4" Margin="0,0,8,4" Padding="10,5"
                                    BorderBrush="#2A4060" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Label}" Foreground="#7BB8F0" FontSize="11"/>
                                    <Button Content="✕" Command="{Binding RemoveCommand}"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="#5588BB" Margin="8,0,0,0" FontSize="10" Cursor="Hand"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Barra de progreso -->
            <Border Grid.Row="2" Background="{StaticResource DarkBg}" Padding="20,0,20,15">
                <StackPanel>
                    <TextBlock Text="{Binding ProgressText}"
                               FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                    <ProgressBar x:Name="ProgressBar" Height="4"
                                 Value="{Binding ProgressValue}"
                                 IsIndeterminate="{Binding IsProgressIndeterminate}"
                                 Foreground="{StaticResource PrimaryColor}"
                                 Background="{StaticResource BorderColor}"
                                 BorderThickness="0"/>
                </StackPanel>
            </Border>

            <!-- Grid de fotos + loading overlay + empty state -->
            <Grid Grid.Row="3">
                <!-- IMP-T3-001: VirtualizingWrapPanel — solo renderiza los elementos visibles -->
                <!-- CanContentScroll="True" es esencial: delega scroll a IScrollInfo del panel -->
                <ItemsControl ItemsSource="{Binding Photos}"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="True"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <controls:VirtualizingWrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.Template>
                        <ControlTemplate TargetType="ItemsControl">
                            <ScrollViewer CanContentScroll="True"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </ControlTemplate>
                    </ItemsControl.Template>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Width" Value="220"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.SelectPhotoCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"
                                    Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                                    Width="220" Margin="8">
                                <Border Style="{StaticResource PhotoCard}" Width="220">
                                    <StackPanel>
                                        <Border Height="180" CornerRadius="8,8,0,0" Background="#1A1A1A">
                                            <!-- IMP-T3-006C: BitmapImageConverter libera file handle y permite GC -->
                                            <Image Source="{Binding ThumbnailPath,
                                                       Converter={StaticResource BitmapImageConv}}"
                                                   Stretch="Uniform"
                                                   VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Margin="12,10,12,12">
                                            <TextBlock Text="{Binding FileName}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="35"/>
                                            <TextBlock Text="{Binding DateTaken, StringFormat='dd/MM/yyyy'}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       Margin="0,5,0,0"/>
                                            <TextBlock Text="{Binding CameraModel}"
                                                       FontSize="9"
                                                       Foreground="{StaticResource TextMuted}"
                                                       Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- F2: Cargar más — fuera del ItemsControl, pegado al fondo del Grid -->
                <Button Command="{Binding LoadMoreCommand}"
                        Visibility="{Binding HasMorePhotos, Converter={StaticResource BoolToVis}}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,8"
                        Padding="24,12"
                        Background="#252525"
                        Foreground="#AAAAAA"
                        FontSize="13">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📥" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding PageInfoText}"/>
                        <TextBlock Text=" — Cargar más" Foreground="#666666"/>
                    </StackPanel>
                </Button>

                <!-- Loading overlay -->
                <Border Visibility="{Binding IsLoadingPhotos, Converter={StaticResource BoolToVis}}"
                        Background="#0F0F0F">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Width="200" Height="3" BorderThickness="0"
                                     Foreground="#0078D4" Background="#252525"/>
                        <TextBlock Text="Cargando fotos..." FontSize="12" Foreground="#666666"
                                   Margin="0,12" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Empty state -->
                <Border Visibility="{Binding HasNoPhotos, Converter={StaticResource BoolToVis}}"
                        Background="#0F0F0F">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="📸" FontSize="72" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="Sin fotos aún" FontSize="20" FontWeight="SemiBold"
                                   Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="Selecciona una carpeta para comenzar a organizar tu colección"
                                   FontSize="13" Foreground="#666666" HorizontalAlignment="Center"
                                   TextAlignment="Center" Margin="0,8,0,24"/>
                        <Button Content="📁 Seleccionar Carpeta" Command="{Binding StartIndexingCommand}"
                                Background="#0078D4" Foreground="White" Padding="20,12" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Barra de estado -->
            <Border Grid.Row="4" Background="{StaticResource PanelBg}"
                    BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0"
                    Padding="20,10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                    <TextBlock Text="{Binding PhotoCountStatus}"
                               Foreground="{StaticResource TextMuted}" FontSize="12" Margin="20,0,0,0"/>
                    <TextBlock Text="{Binding PageInfoText}"
                               Foreground="#444444" FontSize="12" Margin="20,0,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- PANEL DE DETALLE (Col 2) -->
        <controls:PhotoDetailPanel
            Grid.Column="2" Width="360"
            DataContext="{Binding SelectedPhoto}"
            Visibility="{Binding SelectedPhoto, Converter={StaticResource NullToVis}}"/>
    </Grid>
</Window>
