<Window x:Class="Woola.PhotoManager.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Woola Smart Photo Manager" 
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Barra de herramientas -->
        <Border Grid.Row="0" Background="#2D2D2D" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="SelectFolderBtn" 
                        Content="📁 Seleccionar Carpeta" 
                        Padding="10,5"
                        Click="SelectFolderBtn_Click"/>
                <Button x:Name="StopBtn" 
                        Content="⏹️ Detener" 
                        Margin="10,0,0,0" 
                        Padding="10,5"
                        IsEnabled="False"
                        Click="StopBtn_Click"/>
                <TextBlock x:Name="FolderPathText" 
                           Text="Ninguna carpeta seleccionada" 
                           VerticalAlignment="Center" 
                           Margin="20,0,0,0"
                           Foreground="#888888"/>
            </StackPanel>
        </Border>

        <!-- Barra de búsqueda -->
        <Border Grid.Row="1" Background="#252525" Padding="10">
            <TextBox x:Name="SearchBox" 
                     FontSize="14" 
                     Padding="10"
                     Background="#3D3D3D"
                     Foreground="White"
                     BorderThickness="0"
                     TextChanged="SearchBox_TextChanged"/>
        </Border>

        <!-- Barra de progreso -->
        <Grid Grid.Row="2" Margin="10">
            <ProgressBar x:Name="ProgressBar" 
                         Height="4"
                         Foreground="#0078D4"
                         Background="#3D3D3D"/>
            <TextBlock x:Name="ProgressText" 
                       HorizontalAlignment="Right" 
                       VerticalAlignment="Center"
                       Foreground="#888888"
                       FontSize="11"
                       Margin="0,0,10,0"/>
        </Grid>

        <!-- Grid de fotos -->
        <ScrollViewer Grid.Row="3" 
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="PhotoGrid"
                          VirtualizingStackPanel.IsVirtualizing="True">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" Margin="10"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#3D3D3D" 
                                BorderThickness="1" 
                                Margin="5" 
                                Background="#252525" 
                                Width="200"
                                CornerRadius="6">
                            <StackPanel>
                                <Image Source="{Binding ThumbnailPath}" 
                                       Height="160" 
                                       Stretch="Uniform"/>
                                <TextBlock Text="{Binding FileName}" 
                                           FontSize="11" 
                                           TextWrapping="Wrap" 
                                           Margin="8,5,8,0"
                                           Foreground="#DDDDDD"/>
                                <TextBlock Text="{Binding DateTaken, StringFormat='dd/MM/yyyy'}" 
                                           FontSize="10" 
                                           Margin="8,0,8,5"
                                           Foreground="#888888"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Barra de estado -->
        <Border Grid.Row="4" Background="#2D2D2D" Padding="8">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="StatusText" Text="Listo" Foreground="#888888"/>
                <TextBlock x:Name="PhotoCountText" Text="0 fotos" 
                           Margin="20,0,0,0" Foreground="#888888"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
