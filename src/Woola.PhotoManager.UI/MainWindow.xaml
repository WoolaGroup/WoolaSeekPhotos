<Window x:Class="Woola.PhotoManager.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Woola Smart Photo Manager" 
        Height="900" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#0F0F0F"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Colores -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#0078D4"/>
        <SolidColorBrush x:Key="DarkBg" Color="#0F0F0F"/>
        <SolidColorBrush x:Key="PanelBg" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="CardBg" Color="#252525"/>
        <SolidColorBrush x:Key="BorderColor" Color="#333333"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#888888"/>
        <SolidColorBrush x:Key="TextMuted" Color="#555555"/>

        <!-- Botón primario -->
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#333333"/>
                    <Setter Property="Foreground" Value="#666666"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Botón secundario -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2A2A"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Tarjeta de foto -->
        <Style TargetType="Border" x:Key="PhotoCard">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2D2D2D"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ScrollBar personalizado -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR IZQUIERDO -->
        <Border Grid.Column="0" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">
                    <!-- Logo -->
                    <Border Height="60" Margin="0,20,0,30">
                        <TextBlock Text="📸 Woola" FontSize="22" FontWeight="Bold" 
                                   Foreground="{StaticResource PrimaryColor}"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- Botones principales -->
                    <Button x:Name="SelectFolderBtn" Click="SelectFolderBtn_Click" 
                            Background="{StaticResource PrimaryColor}" Margin="0,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📁" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Seleccionar Carpeta"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="StopBtn" Click="StopBtn_Click" IsEnabled="False" 
                            Style="{StaticResource SecondaryButton}" Margin="0,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⏹️" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Detener Indexación"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="PresentationBtn" Click="PresentationBtn_Click" 
                            Style="{StaticResource SecondaryButton}" Margin="0,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎬" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Modo Presentación"/>
                        </StackPanel>
                    </Button>

                    <Separator Margin="0,20" Background="{StaticResource BorderColor}"/>

                    <!-- Estadísticas -->
                    <TextBlock Text="ESTADÍSTICAS" FontSize="11" 
                               Foreground="{StaticResource TextMuted}" 
                               Margin="0,0,0,10"/>

                    <Border Background="{StaticResource CardBg}" CornerRadius="8" Padding="12" Margin="0,5">
                        <StackPanel>
                            <TextBlock Text="📸 Total Fotos" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                            <TextBlock x:Name="PhotoCountText" Text="0" FontSize="24" 
                                       FontWeight="Bold" Foreground="{StaticResource PrimaryColor}"/>
                        </StackPanel>
                    </Border>

                    <Separator Margin="0,20" Background="{StaticResource BorderColor}"/>

                    <!-- Filtros rápidos -->
                    <TextBlock Text="FILTROS RÁPIDOS" FontSize="11" 
                               Foreground="{StaticResource TextMuted}" 
                               Margin="0,0,0,10"/>

                    <Button x:Name="FilterAllBtn" Content="📷 Todas las fotos" 
                            Style="{StaticResource SecondaryButton}" Margin="0,5"/>
                    <Button x:Name="FilterRecentBtn" Content="🕐 Últimos 30 días" 
                            Style="{StaticResource SecondaryButton}" Margin="0,5"/>

                    <!-- Carpeta seleccionada -->
                    <Separator Margin="0,20" Background="{StaticResource BorderColor}"/>
                    <TextBlock Text="CARPETA" FontSize="11" 
                               Foreground="{StaticResource TextMuted}" 
                               Margin="0,0,0,10"/>
                    <TextBlock x:Name="FolderPathText" Text="Ninguna carpeta seleccionada" 
                               FontSize="11" Foreground="{StaticResource TextSecondary}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- PANEL PRINCIPAL DERECHO -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Barra de búsqueda -->
            <Border Grid.Row="0" Background="{StaticResource DarkBg}" Padding="20,15">
                <TextBox x:Name="SearchBox" 
                         FontSize="14" 
                         Padding="15,12"
                         Background="{StaticResource CardBg}"
                         Foreground="{StaticResource TextPrimary}"
                         BorderThickness="0"
                         CaretBrush="{StaticResource PrimaryColor}"
                         TextChanged="SearchBox_TextChanged">
                    <TextBox.Resources>
                        <VisualBrush x:Key="Hint" TileMode="None" Stretch="None" AlignmentX="Left">
                            <VisualBrush.Visual>
                                <TextBlock Text="🔍 Buscar fotos por nombre, fecha o etiqueta..." 
                                           Foreground="{StaticResource TextMuted}" 
                                           FontSize="14" VerticalAlignment="Center"/>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </TextBox.Resources>
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Background" Value="{StaticResource CardBg}"/>
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background" Value="{StaticResource Hint}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </Border>

            <!-- Barra de progreso -->
            <Border Grid.Row="1" Background="{StaticResource DarkBg}" Padding="20,0,20,15">
                <StackPanel>
                    <TextBlock x:Name="ProgressText" Text="Listo" 
                               FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                    <ProgressBar x:Name="ProgressBar" Height="4" 
                                 Foreground="{StaticResource PrimaryColor}"
                                 Background="{StaticResource BorderColor}"
                                 BorderThickness="0"/>
                </StackPanel>
            </Border>

            <!-- Grid de fotos -->
            <ScrollViewer Grid.Row="2" 
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="PhotoGrid"
                              VirtualizingStackPanel.IsVirtualizing="True">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Margin="15"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource PhotoCard}" Width="220">
                                <StackPanel>
                                    <!-- Imagen -->
                                    <Border Height="180" CornerRadius="8,8,0,0" Background="#1A1A1A">
                                        <Image Source="{Binding ThumbnailPath}" 
                                               Stretch="Uniform"
                                               VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Información -->
                                    <StackPanel Margin="12,10,12,12">
                                        <TextBlock Text="{Binding FileName}" 
                                                   FontSize="12" 
                                                   Foreground="{StaticResource TextPrimary}"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="35"/>
                                        <TextBlock Text="{Binding DateTaken, StringFormat='dd/MM/yyyy'}" 
                                                   FontSize="10" 
                                                   Foreground="{StaticResource TextSecondary}"
                                                   Margin="0,5,0,0"/>
                                        <TextBlock Text="{Binding CameraModel}" 
                                                   FontSize="9" 
                                                   Foreground="{StaticResource TextMuted}"
                                                   Margin="0,3,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Barra de estado -->
            <Border Grid.Row="3" Background="{StaticResource PanelBg}" 
                    BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0"
                    Padding="20,10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="StatusText" Text="Listo" 
                               Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                    <TextBlock x:Name="PhotoCountStatus" Text="0 fotos" 
                               Foreground="{StaticResource TextMuted}" FontSize="12" Margin="20,0,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>