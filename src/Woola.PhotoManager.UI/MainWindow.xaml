<Window x:Class="Woola.PhotoManager.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Woola.PhotoManager.UI.Converters"
        xmlns:controls="clr-namespace:Woola.PhotoManager.UI.Controls"
        Title="Woola Photos"
        Height="900" Width="1440"
        MinHeight="680" MinWidth="1024"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrushBgDeep}"
        FontFamily="Segoe UI Variable Display, Segoe UI">

    <Window.Resources>
        <!-- Converters -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolConverter    x:Key="InvBool"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
        <conv:BitmapImageConverter    x:Key="BitmapImageConv"/>

        <!-- Tarjeta de foto — rediseñada -->
        <Style x:Key="PhotoCard" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource BrushBgCard}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BrushBorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background"  Value="{StaticResource BrushBgCardHover}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Fila de lista de foto -->
        <Style x:Key="PhotoListRow" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BrushBgCard}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Tag chip pequeño (sidebar + panel) -->
        <Style x:Key="TagChipSmall" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource BrushBgSelected}"/>
            <Setter Property="CornerRadius"    Value="4"/>
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="Margin"          Value="0,0,5,5"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>

        <!-- Chip de filtro activo -->
        <Style x:Key="FilterChipStyle" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource BrushAccentFaint}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BrushBorderDefault}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="5"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="Margin"          Value="0,0,6,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>    <!-- ROW 0: Top Nav Bar -->
            <RowDefinition Height="48"/>    <!-- ROW 1: Toolbar (search + sort + toggle) -->
            <RowDefinition Height="Auto"/>  <!-- ROW 2: Filter chips (colapsa si no hay) -->
            <RowDefinition Height="*"/>     <!-- ROW 3: Content (left panel + main area) -->
            <RowDefinition Height="30"/>    <!-- ROW 4: Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 0 — TOP NAV BAR
        ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource BrushBgSurface}"
                BorderBrush="{StaticResource BrushBorderSubtle}"
                BorderThickness="0,0,0,1">
            <Grid>
                <!-- Logo — izquierda -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Margin="20,0">
                    <TextBlock Text="Woola"
                               FontSize="15" FontWeight="Bold"
                               Foreground="{StaticResource BrushAccent}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" Photos"
                               FontSize="15"
                               Foreground="{StaticResource BrushTextMuted}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Tabs de navegación — centro -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Stretch">
                    <Button x:Name="TabBiblioteca"
                            Style="{StaticResource NavTabButton}"
                            Content="BIBLIOTECA"
                            Click="TabBiblioteca_Click"/>
                    <Button x:Name="TabAlbumes"
                            Style="{StaticResource NavTabButton}"
                            Content="ÁLBUMES"
                            Click="TabAlbumes_Click"/>
                    <Button x:Name="TabRostros"
                            Style="{StaticResource NavTabButton}"
                            Content="ROSTROS"
                            Click="TabRostros_Click"/>
                    <Button x:Name="TabDiscover"
                            Style="{StaticResource NavTabButton}"
                            Content="DISCOVER"
                            Click="TabDiscover_Click"/>
                </StackPanel>

                <!-- Botones de utilidad — derecha -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="16,0">
                    <Button x:Name="IndexBtn"
                            Style="{StaticResource PrimaryButton}"
                            Content="+ Indexar"
                            Command="{Binding StartIndexingCommand}"
                            IsEnabled="{Binding IsIndexing, Converter={StaticResource InvBool}}"
                            Padding="14,7" Margin="0,0,8,0"/>
                    <Button Style="{StaticResource IconButton}"
                            Content="⊞"
                            Click="DashboardBtn_Click"
                            ToolTip="Dashboard / Estadísticas"
                            Margin="0,0,4,0"/>
                    <Button Style="{StaticResource IconButton}"
                            Content="⚙"
                            Click="SettingsBtn_Click"
                            ToolTip="Configuración"
                            Margin="0,0,4,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 1 — TOOLBAR (búsqueda + controles)
        ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="{StaticResource BrushBgDeep}"
                BorderBrush="{StaticResource BrushBorderSubtle}"
                BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search box -->
                <TextBox x:Name="SearchBox"
                         Grid.Column="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="13"
                         Height="36"
                         Padding="10,0"
                         VerticalAlignment="Center"
                         VerticalContentAlignment="Center">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding HybridSearchCommand}"/>
                    </TextBox.InputBindings>
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush TileMode="None" Stretch="None" AlignmentX="Left" AlignmentY="Center">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="  Buscar fotos..."
                                                               Foreground="#3D4F68"
                                                               FontSize="13"
                                                               Background="#1A2235"
                                                               Padding="10,8"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- Sort ComboBox -->
                <ComboBox x:Name="SortCombo"
                          Grid.Column="1"
                          Width="140"
                          Margin="8,0,0,0"
                          SelectedIndex="0"
                          VerticalAlignment="Center"
                          SelectionChanged="SortCombo_SelectionChanged">
                    <ComboBoxItem Content="Más reciente" Tag="DateDesc"/>
                    <ComboBoxItem Content="Más antigua"  Tag="DateAsc"/>
                    <ComboBoxItem Content="Nombre A–Z"   Tag="NameAsc"/>
                    <ComboBoxItem Content="Tamaño desc"  Tag="SizeDesc"/>
                    <ComboBoxItem Content="Por cámara"   Tag="CameraModel"/>
                </ComboBox>

                <!-- Vista Grid / Lista -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0,0,0"
                            VerticalAlignment="Center">
                    <ToggleButton x:Name="GridViewBtn"
                                  Style="{StaticResource ViewToggleButton}"
                                  Content="⊞"
                                  IsChecked="{Binding IsGridView}"
                                  ToolTip="Vista en cuadrícula"/>
                    <ToggleButton x:Name="ListViewBtn"
                                  Style="{StaticResource ViewToggleButton}"
                                  Content="≡"
                                  IsChecked="{Binding IsListView}"
                                  ToolTip="Vista en lista"
                                  Margin="2,0,0,0"/>
                </StackPanel>

                <!-- AI Búsqueda híbrida -->
                <Button Grid.Column="3"
                        Style="{StaticResource GhostButton}"
                        Content="AI"
                        Command="{Binding HybridSearchCommand}"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        ToolTip="Búsqueda semántica híbrida (Enter)"/>

                <!-- Detener indexación -->
                <Button Grid.Column="4"
                        Style="{StaticResource GhostButton}"
                        Content="■ Detener"
                        Command="{Binding StopIndexingCommand}"
                        Visibility="{Binding IsIndexing, Converter={StaticResource BoolToVis}}"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 2 — FILTER CHIPS + HYBRID MODE
        ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{StaticResource BrushBgDeep}"
                Padding="16,6,16,6">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsHybridModeVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ActiveFilters.Count}" Value="0">
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel>
                <!-- Modo híbrido activo -->
                <Border Background="{StaticResource BrushAccentFaint}"
                        BorderBrush="{StaticResource BrushAccent}"
                        BorderThickness="1"
                        CornerRadius="5"
                        Padding="10,5"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,4"
                        Visibility="{Binding IsHybridModeVisible, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="AI"
                                   Foreground="{StaticResource BrushAccent}"
                                   FontSize="10" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding HybridModeLabel}"
                                   Foreground="{StaticResource BrushAccentText}"
                                   FontSize="11" VerticalAlignment="Center"/>
                        <Button Content="✕"
                                Command="{Binding ClearSearchCommand}"
                                Style="{StaticResource GhostButton}"
                                Foreground="{StaticResource BrushTextMuted}"
                                FontSize="10" Padding="6,2"
                                Margin="8,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Chips de filtros activos -->
                <ItemsControl ItemsSource="{Binding ActiveFilters}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource FilterChipStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Label}"
                                               Foreground="{StaticResource BrushAccentText}"
                                               FontSize="11" VerticalAlignment="Center"/>
                                    <Button Content="✕"
                                            Command="{Binding RemoveCommand}"
                                            Style="{StaticResource GhostButton}"
                                            Foreground="{StaticResource BrushTextMuted}"
                                            FontSize="9" Padding="4,1"
                                            Margin="6,0,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 3 — CONTENT: Left Panel + Main Area
        ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─── LEFT PANEL — Filtros contextuales ─────────────── -->
            <Border Grid.Column="0"
                    Background="{StaticResource BrushBgSurface}"
                    BorderBrush="{StaticResource BrushBorderSubtle}"
                    BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8,0,16">

                        <!-- Progreso de indexación -->
                        <Border Padding="14,10"
                                Visibility="{Binding IsIndexing, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="{Binding ProgressText}"
                                           FontSize="11"
                                           Foreground="{StaticResource BrushTextSecondary}"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,0,5"/>
                                <ProgressBar Value="{Binding ProgressValue}"
                                             IsIndeterminate="{Binding IsProgressIndeterminate}"/>
                            </StackPanel>
                        </Border>

                        <!-- SECCIÓN: Filtrar -->
                        <TextBlock Text="FILTRAR"
                                   Style="{StaticResource SectionLabel}"
                                   Margin="16,8,16,4"/>

                        <Button Content="Todas las fotos"
                                Style="{StaticResource LeftNavItem}"
                                Command="{Binding FilterAllCommand}"/>
                        <Button Content="Últimos 30 días"
                                Style="{StaticResource LeftNavItem}"
                                Command="{Binding FilterRecentCommand}"/>
                        <Button Content="Duplicados"
                                Style="{StaticResource LeftNavItem}"
                                Click="DuplicatesBtn_Click"/>
                        <Button Content="Presentación"
                                Style="{StaticResource LeftNavItem}"
                                Click="PresentationBtn_Click"/>

                        <Separator Margin="14,8"/>

                        <!-- SECCIÓN: Álbumes -->
                        <TextBlock Text="ÁLBUMES"
                                   Style="{StaticResource SectionLabel}"
                                   Margin="16,0,16,4"/>

                        <ItemsControl ItemsSource="{Binding SidebarAlbums}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource LeftNavItem}"
                                            Command="{Binding DataContext.FilterByAlbumCommand,
                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="32"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Miniatura de portada del álbum -->
                                            <Border Grid.Column="0"
                                                    Width="24" Height="24"
                                                    CornerRadius="3"
                                                    Background="{StaticResource BrushBgCardHover}"
                                                    ClipToBounds="True">
                                                <Image Source="{Binding CoverThumbnailPath,
                                                           Converter={StaticResource BitmapImageConv}}"
                                                       Stretch="UniformToFill"/>
                                            </Border>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Name}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"
                                                       Margin="6,0,4,0"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding PhotoCount}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource BrushTextMuted}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button Content="Gestionar álbumes"
                                Style="{StaticResource LeftNavItem}"
                                Click="AlbumsBtn_Click"
                                Foreground="{StaticResource BrushAccentText}"/>

                        <Separator Margin="14,8"/>

                        <!-- SECCIÓN: Eventos -->
                        <TextBlock Text="EVENTOS"
                                   Style="{StaticResource SectionLabel}"
                                   Margin="16,0,16,4"/>

                        <ItemsControl ItemsSource="{Binding Events}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource LeftNavItem}"
                                            Command="{Binding DataContext.FilterByEventCommand,
                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding DisplayName}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding CountLabel}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource BrushTextMuted}"
                                                       Margin="6,0,0,0"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Margin="14,8"/>

                        <!-- SECCIÓN: Etiquetas populares -->
                        <TextBlock Text="ETIQUETAS"
                                   Style="{StaticResource SectionLabel}"
                                   Margin="16,0,16,4"/>

                        <ItemsControl ItemsSource="{Binding Tags}" Margin="10,0,10,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Margin="6,0"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource GhostButton}"
                                            Content="{Binding Name}"
                                            Padding="8,4" FontSize="11" Margin="2,2"
                                            Command="{Binding DataContext.FilterByTagCommand,
                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding Name}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="4"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource BrushBgSelected}"/>
                                                        <Setter Property="Foreground" Value="{StaticResource BrushAccentText}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Margin="14,10"/>

                        <!-- SECCIÓN: Herramientas -->
                        <TextBlock Text="HERRAMIENTAS"
                                   Style="{StaticResource SectionLabel}"
                                   Margin="16,0,16,4"/>

                        <Button Content="Reprocesar tags"
                                Style="{StaticResource LeftNavItem}"
                                x:Name="ReprocessTagsBtn"
                                Click="ReprocessTagsBtn_Click"/>
                        <Button Content="Test Vision"
                                Style="{StaticResource LeftNavItem}"
                                Click="TestVisionBtn_Click"
                                Foreground="{StaticResource BrushTextMuted}"/>
                        <Button Content="Test OCR"
                                Style="{StaticResource LeftNavItem}"
                                Click="TestOcrBtn_Click"
                                Foreground="{StaticResource BrushTextMuted}"/>

                        <!-- Carpeta activa (footer del panel) -->
                        <Separator Margin="14,10"/>
                        <TextBlock Text="CARPETA"
                                   Style="{StaticResource SectionLabel}"
                                   Margin="16,0,16,4"/>
                        <TextBlock Text="{Binding FolderPathText}"
                                   FontSize="11"
                                   Foreground="{StaticResource BrushTextMuted}"
                                   TextWrapping="Wrap"
                                   Margin="14,0,14,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ─── MAIN AREA — Grid de fotos + detalle ───────────── -->
            <Grid Grid.Column="1">
                <!-- Loading overlay -->
                <Border Visibility="{Binding IsLoadingPhotos, Converter={StaticResource BoolToVis}}"
                        Background="{StaticResource BrushBgDeep}"
                        Panel.ZIndex="10">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Width="180"/>
                        <TextBlock Text="Cargando fotos..."
                                   FontSize="12" Foreground="{StaticResource BrushTextMuted}"
                                   Margin="0,12" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Empty state -->
                <Border Visibility="{Binding HasNoPhotos, Converter={StaticResource BoolToVis}}"
                        Background="{StaticResource BrushBgDeep}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="○" FontSize="56"
                                   Foreground="{StaticResource BrushBorderDefault}"
                                   HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="Sin fotos aún"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushTextPrimary}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Selecciona una carpeta para comenzar"
                                   FontSize="13" Foreground="{StaticResource BrushTextMuted}"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,24"/>
                        <Button Content="+ Indexar carpeta"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding StartIndexingCommand}"
                                HorizontalAlignment="Center"
                                Padding="20,10"/>
                    </StackPanel>
                </Border>

                <!-- VISTA GRID — VirtualizingWrapPanel -->
                <ItemsControl ItemsSource="{Binding Photos}"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="True"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding IsGridView, Converter={StaticResource BoolToVis}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <controls:VirtualizingWrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.Template>
                        <ControlTemplate TargetType="ItemsControl">
                            <ScrollViewer CanContentScroll="True"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </ControlTemplate>
                    </ItemsControl.Template>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.SelectPhotoCommand,
                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="0" Cursor="Hand" Width="220" Margin="5">
                                <Border Style="{StaticResource PhotoCard}" Width="220">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="165"/>
                                            <RowDefinition Height="50"/>
                                        </Grid.RowDefinitions>
                                        <!-- Imagen — recorte UniformToFill en borde redondeado -->
                                        <Border Grid.Row="0"
                                                CornerRadius="8,8,0,0"
                                                Background="{StaticResource BrushBgDeep}"
                                                ClipToBounds="True">
                                            <Image Source="{Binding ThumbnailPath,
                                                       Converter={StaticResource BitmapImageConv}}"
                                                   Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   VerticalAlignment="Center"/>
                                        </Border>
                                        <!-- Info — limpia, solo filename y fecha -->
                                        <Grid Grid.Row="1" Margin="10,9,10,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0"
                                                       Text="{Binding FileName}"
                                                       FontSize="12" FontWeight="Medium"
                                                       Foreground="{StaticResource BrushTextPrimary}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding DateTaken, StringFormat=dd\ MMM\ yyyy, TargetNullValue='—'}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource BrushTextMuted}"
                                                       Margin="0,3,0,0"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- VISTA LISTA -->
                <ItemsControl ItemsSource="{Binding Photos}"
                              VirtualizingPanel.IsVirtualizing="True"
                              Visibility="{Binding IsListView, Converter={StaticResource BoolToVis}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.Template>
                        <ControlTemplate TargetType="ItemsControl">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </ControlTemplate>
                    </ItemsControl.Template>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.SelectPhotoCommand,
                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="0" Cursor="Hand"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch">
                                <Border Style="{StaticResource PhotoListRow}"
                                        Height="72" HorizontalAlignment="Stretch">
                                    <Grid Margin="16,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Miniatura -->
                                        <Border Grid.Column="0"
                                                Width="52" Height="52"
                                                CornerRadius="5"
                                                Background="{StaticResource BrushBgCard}"
                                                ClipToBounds="True"
                                                VerticalAlignment="Center">
                                            <Image Source="{Binding ThumbnailPath,
                                                       Converter={StaticResource BitmapImageConv}}"
                                                   Stretch="UniformToFill"/>
                                        </Border>
                                        <!-- Nombre + cámara -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0">
                                            <TextBlock Text="{Binding FileName}"
                                                       FontSize="13" FontWeight="Medium"
                                                       Foreground="{StaticResource BrushTextPrimary}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding CameraModel}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource BrushTextMuted}"
                                                       Margin="0,3,0,0"/>
                                        </StackPanel>
                                        <!-- Fecha -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding DateTaken, StringFormat=dd\ MMM\ yyyy, TargetNullValue='—'}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource BrushTextSecondary}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Botón "Cargar más" -->
                <Button Command="{Binding LoadMoreCommand}"
                        Visibility="{Binding HasMorePhotos, Converter={StaticResource BoolToVis}}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,0,12"
                        Padding="20,10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding PageInfoText}"
                                   Foreground="{StaticResource BrushTextSecondary}"/>
                        <TextBlock Text=" — Cargar más"
                                   Foreground="{StaticResource BrushTextMuted}"/>
                    </StackPanel>
                </Button>

                <!-- Panel de detalle — slide-in desde la derecha -->
                <controls:PhotoDetailPanel
                    HorizontalAlignment="Right"
                    Width="340"
                    DataContext="{Binding SelectedPhoto}"
                    Visibility="{Binding DataContext.SelectedPhoto, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource NullToVis}}"
                    Panel.ZIndex="5"/>
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 4 — STATUS BAR
        ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="4"
                Background="{StaticResource BrushBgStatusBar}"
                BorderBrush="{StaticResource BrushBorderSubtle}"
                BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Izquierda: estado / progreso -->
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusText}"
                           FontSize="11"
                           Foreground="{StaticResource BrushTextMuted}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>

                <!-- Derecha: conteo de fotos -->
                <TextBlock Grid.Column="1"
                           Text="{Binding PhotoCountStatus}"
                           FontSize="11"
                           Foreground="{StaticResource BrushTextSecondary}"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"/>

                <!-- Info de paginación -->
                <TextBlock Grid.Column="2"
                           Text="{Binding PageInfoText}"
                           FontSize="11"
                           Foreground="{StaticResource BrushTextMuted}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
