<UserControl x:Class="Woola.PhotoManager.UI.Controls.PhotoDetailPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Margin" Value="0,16,0,6"/>
        </Style>

        <Style x:Key="DetailLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="Width" Value="90"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>

        <Style x:Key="DetailValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </UserControl.Resources>

    <Border BorderBrush="#333333" BorderThickness="1,0,0,0" Background="#141414">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="220"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header: filename + close button -->
            <Border Grid.Row="0" Background="#0F0F0F"
                    BorderBrush="#333333" BorderThickness="0,0,0,1" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding FileName}"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="White"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="✕"
                            Command="{Binding CloseCommand}"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#666666" FontSize="14"
                            Cursor="Hand" Padding="8,4"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Photo preview -->
            <Border Grid.Row="1" Background="#0A0A0A">
                <Image Source="{Binding ThumbnailPath}"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </Border>

            <!-- Scrollable details -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16,8,16,16">

                    <!-- Loading state -->
                    <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                                Margin="0,12,0,0">
                        <ProgressBar IsIndeterminate="True" Height="3" BorderThickness="0"
                                     Foreground="#0078D4" Background="#252525"/>
                        <TextBlock Text="Cargando detalles..." FontSize="11"
                                   Foreground="#555555" HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- ARCHIVO -->
                    <TextBlock Text="ARCHIVO" Style="{StaticResource SectionHeader}"/>

                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="Tamaño" Style="{StaticResource DetailLabel}"/>
                        <TextBlock Text="{Binding FileSize}" Style="{StaticResource DetailValue}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="Resolución" Style="{StaticResource DetailLabel}"/>
                        <TextBlock Text="{Binding Resolution}" Style="{StaticResource DetailValue}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="Fecha" Style="{StaticResource DetailLabel}"/>
                        <TextBlock Text="{Binding DateTaken, StringFormat='dd/MM/yyyy HH:mm'}"
                                   Style="{StaticResource DetailValue}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="Indexado" Style="{StaticResource DetailLabel}"/>
                        <TextBlock Text="{Binding IndexedAt}" Style="{StaticResource DetailValue}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="Ruta" Style="{StaticResource DetailLabel}"/>
                        <TextBlock Text="{Binding FilePath}" Style="{StaticResource DetailValue}"
                                   MaxWidth="230" TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding FilePath}"/>
                    </StackPanel>

                    <!-- CÁMARA / EXIF -->
                    <TextBlock Text="CÁMARA" Style="{StaticResource SectionHeader}"/>

                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="Modelo" Style="{StaticResource DetailLabel}"/>
                        <TextBlock Text="{Binding CameraModel}" Style="{StaticResource DetailValue}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="Lente" Style="{StaticResource DetailLabel}"/>
                        <TextBlock Text="{Binding LensModel}" Style="{StaticResource DetailValue}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="Apertura" Style="{StaticResource DetailLabel}"/>
                        <TextBlock Text="{Binding Aperture}" Style="{StaticResource DetailValue}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="Velocidad" Style="{StaticResource DetailLabel}"/>
                        <TextBlock Text="{Binding ShutterSpeed}" Style="{StaticResource DetailValue}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="ISO" Style="{StaticResource DetailLabel}"/>
                        <TextBlock Text="{Binding Iso}" Style="{StaticResource DetailValue}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="Focal" Style="{StaticResource DetailLabel}"/>
                        <TextBlock Text="{Binding FocalLength}" Style="{StaticResource DetailValue}"/>
                    </StackPanel>

                    <!-- TAGS -->
                    <TextBlock Text="TAGS" Style="{StaticResource SectionHeader}"/>
                    <ItemsControl ItemsSource="{Binding Tags}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1A2A3A" CornerRadius="3"
                                        Margin="0,0,6,6" Padding="8,4">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="10" Foreground="#7BB8F0"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- ROSTROS -->
                    <TextBlock Text="ROSTROS" Style="{StaticResource SectionHeader}"/>
                    <TextBlock Text="{Binding FaceSummary}"
                               FontSize="11" Foreground="#AAAAAA"
                               TextWrapping="Wrap"/>

                    <!-- G1: ÁLBUMES -->
                    <TextBlock Text="ÁLBUM" Style="{StaticResource SectionHeader}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <ComboBox ItemsSource="{Binding AvailableAlbums}"
                                  SelectedItem="{Binding SelectedAlbum}"
                                  DisplayMemberPath="Name"
                                  Width="155" Height="28"
                                  Background="#252525" Foreground="White"
                                  BorderBrush="#444444" FontSize="11"
                                  VerticalContentAlignment="Center"/>
                        <Button Content="＋ Agregar"
                                Command="{Binding AddToAlbumCommand}"
                                Background="#0078D4" Foreground="White"
                                BorderThickness="0" Padding="10,5"
                                Margin="8,0,0,0" FontSize="11" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.4"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                    <TextBlock Text="{Binding AlbumAddStatus}"
                               FontSize="10" Foreground="#7BB8F0" Margin="0,5,0,0"/>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
