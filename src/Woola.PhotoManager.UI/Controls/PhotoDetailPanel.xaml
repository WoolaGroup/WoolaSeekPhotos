<UserControl x:Class="Woola.PhotoManager.UI.Controls.PhotoDetailPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="DetailLabel" TargetType="TextBlock">
            <Setter Property="FontSize"          Value="11"/>
            <Setter Property="Foreground"        Value="{StaticResource BrushTextMuted}"/>
            <Setter Property="Width"             Value="86"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>

        <Style x:Key="DetailValue" TargetType="TextBlock">
            <Setter Property="FontSize"      Value="11"/>
            <Setter Property="Foreground"    Value="{StaticResource BrushTextSecondary}"/>
            <Setter Property="TextWrapping"  Value="Wrap"/>
        </Style>

        <!-- Tab item — subrayado activo, sin chrome -->
        <Style x:Key="DetailTabItem" TargetType="TabItem">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                BorderBrush="Transparent"
                                BorderThickness="0,0,0,2"
                                Padding="13,0,13,2"
                                Height="36"
                                Background="Transparent"
                                Cursor="Hand">
                            <TextBlock x:Name="TabText"
                                       Text="{TemplateBinding Header}"
                                       FontSize="10" FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource BrushTextMuted}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush"
                                        Value="{StaticResource BrushAccent}"/>
                                <Setter TargetName="TabText"   Property="Foreground"
                                        Value="{StaticResource BrushTextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabText" Property="Foreground"
                                        Value="{StaticResource BrushTextSecondary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource BrushBgSurface}"
            BorderBrush="{StaticResource BrushBorderSubtle}"
            BorderThickness="1,0,0,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Header -->
                <RowDefinition Height="200"/>   <!-- Preview -->
                <RowDefinition Height="*"/>     <!-- Tabs -->
            </Grid.RowDefinitions>

            <!-- ── Header: nombre + botón cerrar ───────────────────────── -->
            <Border Grid.Row="0"
                    Background="{StaticResource BrushBgDeep}"
                    BorderBrush="{StaticResource BrushBorderSubtle}"
                    BorderThickness="0,0,0,1"
                    Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding FileName}"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextPrimary}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Content="✕"
                            Command="{Binding CloseCommand}"
                            Style="{StaticResource GhostButton}"
                            FontSize="13" Padding="8,4"
                            Foreground="{StaticResource BrushTextMuted}"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ── Vista previa ─────────────────────────────────────────── -->
            <Border Grid.Row="1" Background="{StaticResource BrushBgDeep}">
                <Image Source="{Binding ThumbnailPath}"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </Border>

            <!-- ── Detalles en pestañas ──────────────────────────────────── -->
            <TabControl Grid.Row="2"
                        Background="{StaticResource BrushBgSurface}"
                        BorderThickness="0"
                        ItemContainerStyle="{StaticResource DetailTabItem}">

                <TabControl.Template>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="36"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- Franja de pestañas -->
                            <Border Grid.Row="0"
                                    Background="{StaticResource BrushBgSurface}"
                                    BorderBrush="{StaticResource BrushBorderSubtle}"
                                    BorderThickness="0,0,0,1">
                                <TabPanel IsItemsHost="True" Background="Transparent"/>
                            </Border>
                            <!-- Contenido de la pestaña activa -->
                            <ContentPresenter Grid.Row="1"
                                              x:Name="PART_SelectedContentHost"
                                              ContentSource="SelectedContent"/>
                        </Grid>
                    </ControlTemplate>
                </TabControl.Template>

                <!-- ═══ PESTAÑA 1 — INFO ════════════════════════════════ -->
                <TabItem Header="INFO">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Background="{StaticResource BrushBgSurface}">
                        <StackPanel Margin="16,8,16,16">

                            <!-- Cargando -->
                            <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                                        Margin="0,10,0,0">
                                <ProgressBar IsIndeterminate="True"/>
                                <TextBlock Text="Cargando detalles..."
                                           FontSize="11"
                                           Foreground="{StaticResource BrushTextMuted}"
                                           HorizontalAlignment="Center"
                                           Margin="0,8,0,0"/>
                            </StackPanel>

                            <!-- ARCHIVO -->
                            <TextBlock Text="ARCHIVO" Style="{StaticResource SectionLabel}"/>

                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <TextBlock Text="Tamaño"    Style="{StaticResource DetailLabel}"/>
                                <TextBlock Text="{Binding FileSize}" Style="{StaticResource DetailValue}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <TextBlock Text="Resolución" Style="{StaticResource DetailLabel}"/>
                                <TextBlock Text="{Binding Resolution}" Style="{StaticResource DetailValue}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <TextBlock Text="Fecha"     Style="{StaticResource DetailLabel}"/>
                                <TextBlock Text="{Binding DateTaken, StringFormat='dd/MM/yyyy HH:mm'}"
                                           Style="{StaticResource DetailValue}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <TextBlock Text="Indexado"  Style="{StaticResource DetailLabel}"/>
                                <TextBlock Text="{Binding IndexedAt}" Style="{StaticResource DetailValue}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <TextBlock Text="Ruta"      Style="{StaticResource DetailLabel}"/>
                                <TextBlock Text="{Binding FilePath}"
                                           Style="{StaticResource DetailValue}"
                                           MaxWidth="218"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding FilePath}"/>
                            </StackPanel>

                            <!-- CÁMARA / EXIF -->
                            <TextBlock Text="CÁMARA" Style="{StaticResource SectionLabel}"/>

                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <TextBlock Text="Modelo"    Style="{StaticResource DetailLabel}"/>
                                <TextBlock Text="{Binding CameraModel}" Style="{StaticResource DetailValue}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <TextBlock Text="Lente"     Style="{StaticResource DetailLabel}"/>
                                <TextBlock Text="{Binding LensModel}" Style="{StaticResource DetailValue}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <TextBlock Text="Apertura"  Style="{StaticResource DetailLabel}"/>
                                <TextBlock Text="{Binding Aperture}" Style="{StaticResource DetailValue}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <TextBlock Text="Velocidad" Style="{StaticResource DetailLabel}"/>
                                <TextBlock Text="{Binding ShutterSpeed}" Style="{StaticResource DetailValue}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <TextBlock Text="ISO"       Style="{StaticResource DetailLabel}"/>
                                <TextBlock Text="{Binding Iso}" Style="{StaticResource DetailValue}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <TextBlock Text="Focal"     Style="{StaticResource DetailLabel}"/>
                                <TextBlock Text="{Binding FocalLength}" Style="{StaticResource DetailValue}"/>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ═══ PESTAÑA 2 — ETIQUETAS ═══════════════════════════ -->
                <TabItem Header="ETIQUETAS">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Background="{StaticResource BrushBgSurface}">
                        <StackPanel Margin="16,12,16,16">

                            <ItemsControl ItemsSource="{Binding Tags}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource BrushBgSelected}"
                                                CornerRadius="4"
                                                Margin="0,0,5,5"
                                                Padding="9,4">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource BrushAccentText}"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Estado vacío -->
                            <TextBlock Text="Sin etiquetas aún"
                                       FontSize="12"
                                       Foreground="{StaticResource BrushTextMuted}"
                                       HorizontalAlignment="Center"
                                       Margin="0,18,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock"
                                           BasedOn="{StaticResource {x:Type TextBlock}}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Tags.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Separator Margin="0,14"/>

                            <!-- IMP-009: Fotos similares -->
                            <Button x:Name="SimilarPhotosBtn"
                                    Content="Ver fotos similares"
                                    Click="SimilarPhotosBtn_Click"
                                    Style="{StaticResource SecondaryButton}"
                                    HorizontalAlignment="Left"
                                    Padding="12,6" FontSize="11"/>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ═══ PESTAÑA 3 — ROSTROS ═════════════════════════════ -->
                <TabItem Header="ROSTROS">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Background="{StaticResource BrushBgSurface}">
                        <StackPanel Margin="16,12,16,16">
                            <TextBlock Text="{Binding FaceSummary}"
                                       FontSize="12"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ═══ PESTAÑA 4 — ÁLBUMES ═════════════════════════════ -->
                <TabItem Header="ÁLBUMES">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Background="{StaticResource BrushBgSurface}">
                        <StackPanel Margin="16,12,16,16">

                            <TextBlock Text="AÑADIR A ÁLBUM"
                                       Style="{StaticResource SectionLabel}"/>

                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <ComboBox ItemsSource="{Binding AvailableAlbums}"
                                          SelectedItem="{Binding SelectedAlbum}"
                                          DisplayMemberPath="Name"
                                          Width="148"
                                          VerticalContentAlignment="Center"/>
                                <Button Content="Agregar"
                                        Command="{Binding AddToAlbumCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Padding="10,5"
                                        Margin="8,0,0,0"
                                        FontSize="11"/>
                            </StackPanel>

                            <TextBlock Text="{Binding AlbumAddStatus}"
                                       FontSize="11"
                                       Foreground="{StaticResource BrushAccentText}"
                                       Margin="0,8,0,0"/>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>
        </Grid>
    </Border>
</UserControl>
