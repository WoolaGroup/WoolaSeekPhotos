<Window x:Class="Woola.PhotoManager.UI.PresentationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Modo Presentación" 
        WindowState="Maximized"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Black"
        Topmost="True"
        KeyDown="Window_KeyDown">

    <Grid>
        <Image x:Name="CurrentImage" Stretch="Uniform" VerticalAlignment="Center"/>

        <!-- Overlay inferior -->
        <Border VerticalAlignment="Bottom" Background="#80000000" Padding="20" Margin="50">
            <TextBlock x:Name="InfoText" Foreground="White" FontSize="16" TextAlignment="Center"/>
        </Border>

        <!-- Instrucciones -->
        <Border VerticalAlignment="Top" HorizontalAlignment="Right" Background="#80000000" Padding="10,5" Margin="20">
            <TextBlock Text="← →  navegar | ESC  salir" Foreground="#CCCCCC" FontSize="12"/>
        </Border>
    </Grid>
</Window>