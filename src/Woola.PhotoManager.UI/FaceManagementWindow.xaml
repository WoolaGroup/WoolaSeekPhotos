<Window x:Class="Woola.PhotoManager.UI.FaceManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestión de Rostros" Height="700" Width="1100"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrushBgDeep}">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <Border Grid.Row="0" Style="{StaticResource WindowHeaderBorder}" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Gestión de Rostros" Style="{StaticResource WindowHeaderTitle}"/>
                <TextBlock Text="Agrupa rostros similares y asígnales nombres para identificarlos en tus fotos"
                           Style="{StaticResource WindowHeaderSubtitle}"/>
            </StackPanel>
        </Border>

        <!-- Lista de grupos de personas -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="PersonGroupsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource BrushBgCard}"
                                CornerRadius="8" Margin="0,0,0,10" Padding="15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Miniaturas de rostros -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,20,0">
                                    <ItemsControl ItemsSource="{Binding FaceThumbnails}" MaxWidth="300">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="60" Height="60" CornerRadius="30"
                                                        Background="{StaticResource BrushBgCardHover}"
                                                        Margin="2">
                                                    <Image Source="{Binding}" Stretch="UniformToFill"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <!-- Nombre y estadísticas -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="Bold"
                                               Foreground="{StaticResource BrushTextPrimary}"/>
                                    <TextBlock FontSize="11" Foreground="{StaticResource BrushTextMuted}">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0} fotos, {1} rostros">
                                                <Binding Path="PhotoCount"/>
                                                <Binding Path="FaceCount"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Botones de acción -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <!-- TextBox inline con placeholder para asignar nombre -->
                                    <Grid Width="160" VerticalAlignment="Center" Margin="0,0,10,0">
                                        <TextBox x:Name="NameInput"
                                                 Height="30" Padding="8,4" FontSize="11"
                                                 Tag="{Binding}"
                                                 KeyDown="NameBox_KeyDown"
                                                 VerticalContentAlignment="Center"/>
                                        <TextBlock Text="Asignar nombre..." IsHitTestVisible="False"
                                                   Foreground="{StaticResource BrushTextMuted}"
                                                   FontSize="11" Padding="11,0" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ElementName=NameInput, Path=Text}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <Button Content="Ver Fotos" Style="{StaticResource SecondaryButton}"
                                            Click="ViewPhotos_Click" Tag="{Binding}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Barra de estado -->
        <Border Grid.Row="2" Background="{StaticResource BrushBgCard}"
                CornerRadius="8" Padding="15" Margin="0,15,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="StatusText" Text="Listo"
                           Foreground="{StaticResource BrushTextMuted}" FontSize="12"
                           VerticalAlignment="Center"/>
                <Button Content="Reprocesar Rostros" Style="{StaticResource SecondaryButton}"
                        Margin="20,0,0,0" Click="ReprocessFaces_Click"/>
                <Button Content="Agrupar por Similitud" Style="{StaticResource SecondaryButton}"
                        Margin="10,0,0,0" Click="ClusterAndSave_Click"/>
                <Button Content="Probar imagen" Style="{StaticResource SecondaryButton}"
                        Margin="10,0,0,0" Click="TestSingleImage_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
