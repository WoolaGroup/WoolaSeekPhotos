<Window x:Class="Woola.PhotoManager.UI.FaceManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestión de Rostros" Height="700" Width="1100"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A1A">

    <Window.Resources>
        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="SecondaryButton">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D3D3D"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <Border Grid.Row="0" Style="{StaticResource WindowHeaderBorder}" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="👤 Gestión de Rostros" Style="{StaticResource WindowHeaderTitle}"/>
                <TextBlock Text="Agrupa rostros similares y asígnales nombres para identificarlos en tus fotos"
                           Style="{StaticResource WindowHeaderSubtitle}"/>
            </StackPanel>
        </Border>

        <!-- Lista de grupos de personas -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="PersonGroupsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#252525" CornerRadius="8" Margin="0,0,0,10" Padding="15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Miniaturas de rostros -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,20,0">
                                    <ItemsControl ItemsSource="{Binding FaceThumbnails}" MaxWidth="300">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="60" Height="60" CornerRadius="30" 
                                                        Background="#3D3D3D" Margin="2">
                                                    <Image Source="{Binding}" Stretch="UniformToFill"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <!-- Nombre y estadísticas (CORREGIDO) -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock FontSize="11" Foreground="#888888">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0} fotos, {1} rostros">
                                                <Binding Path="PhotoCount"/>
                                                <Binding Path="FaceCount"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Botones de acción -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="✏️ Asignar Nombre" Style="{StaticResource SecondaryButton}" 
                                            Click="AssignName_Click" Tag="{Binding}"/>
                                    <Button Content="🔍 Ver Fotos" Style="{StaticResource SecondaryButton}" 
                                            Margin="10,0,0,0" Click="ViewPhotos_Click" Tag="{Binding}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Button Content="🧪 Probar una imagen" Style="{StaticResource SecondaryButton}" 
        Margin="10,0,0,0" Click="TestSingleImage_Click"/>

        <!-- Barra de estado -->
        <Border Grid.Row="2" Background="#252525" CornerRadius="8" Padding="15" Margin="0,15,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="StatusText" Text="Listo" Foreground="#888888" FontSize="12"/>
                <Button Content="🔄 Reprocesar Rostros" Style="{StaticResource SecondaryButton}" 
                        Margin="20,0,0,0" Click="ReprocessFaces_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>