<Window x:Class="Woola.PhotoManager.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuración"
        Width="520" Height="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BrushBgDeep}"
        FontFamily="Segoe UI Variable Display, Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- ROW 0: Header -->
            <RowDefinition Height="*"/>      <!-- ROW 1: Contenido scrollable -->
            <RowDefinition Height="1"/>      <!-- ROW 2: Separador -->
            <RowDefinition Height="Auto"/>   <!-- ROW 3: Botones -->
        </Grid.RowDefinitions>

        <!-- ROW 0 — Header ─────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Style="{StaticResource WindowHeaderBorder}">
            <StackPanel>
                <TextBlock Text="Configuración"
                           Style="{StaticResource WindowHeaderTitle}"/>
                <TextBlock Text="Personaliza los agentes, el clustering facial y la importación cloud"
                           Style="{StaticResource WindowHeaderSubtitle}"/>
            </StackPanel>
        </Border>

        <!-- ROW 1 — Contenido ──────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="20,0,20,20">
            <StackPanel>

                <!-- ── AGENTES DE INDEXACIÓN ────────────────────────────── -->
                <TextBlock Text="AGENTES DE INDEXACIÓN"
                           Style="{StaticResource SectionLabel}"
                           Margin="0,16,0,8"/>

                <Border Background="{StaticResource BrushBgCard}"
                        CornerRadius="8" Padding="4">
                    <ScrollViewer MaxHeight="240"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="AgentsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="Transparent"
                                            Padding="12,8"
                                            CornerRadius="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsEnabled}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,12,0"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource BrushTextPrimary}"/>
                                                <TextBlock Text="{Binding Description}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource BrushTextMuted}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- ── CLUSTERING FACIAL ────────────────────────────────── -->
                <TextBlock Text="CLUSTERING FACIAL"
                           Style="{StaticResource SectionLabel}"
                           Margin="0,20,0,8"/>

                <Border Background="{StaticResource BrushBgCard}"
                        CornerRadius="8" Padding="16">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Umbral de similitud coseno"
                                       FontSize="13"
                                       Foreground="{StaticResource BrushTextPrimary}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="ThresholdValueText"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource BrushAccent}"/>
                        </Grid>
                        <Slider x:Name="ThresholdSlider"
                                Minimum="0.50" Maximum="0.90"
                                TickFrequency="0.05"
                                IsSnapToTickEnabled="True"
                                ValueChanged="ThresholdSlider_ValueChanged"
                                Foreground="{StaticResource BrushAccent}"
                                Margin="0,4,0,0"/>
                        <Grid Margin="0,4,0,0">
                            <TextBlock Text="0.50 (más agrupado)"
                                       FontSize="10"
                                       Foreground="{StaticResource BrushTextMuted}"
                                       HorizontalAlignment="Left"/>
                            <TextBlock Text="0.90 (más estricto)"
                                       FontSize="10"
                                       Foreground="{StaticResource BrushTextMuted}"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── IMPORTACIÓN CLOUD ─────────────────────────────────── -->
                <TextBlock Text="IMPORTACIÓN CLOUD"
                           Style="{StaticResource SectionLabel}"
                           Margin="0,20,0,8"/>

                <Border Background="{StaticResource BrushBgCard}"
                        CornerRadius="8" Padding="16">
                    <StackPanel>

                        <!-- Carpeta destino -->
                        <TextBlock Text="Carpeta destino para fotos importadas"
                                   FontSize="12"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ImportDestPathBox"
                                     Grid.Column="0"
                                     IsReadOnly="True"
                                     Height="32"
                                     Padding="8,0"
                                     VerticalContentAlignment="Center"
                                     FontSize="12"/>
                            <Button Grid.Column="1"
                                    Content="Examinar"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="8,0,0,0"
                                    Padding="12,4" Height="32"
                                    Click="BrowseDestBtn_Click"/>
                        </Grid>

                        <!-- Override ruta Google Drive -->
                        <TextBlock Text="Ruta de Google Drive local (vacío = autodetectar)"
                                   FontSize="12"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="GoogleDrivePathBox"
                                     Grid.Column="0"
                                     IsReadOnly="True"
                                     Height="32"
                                     Padding="8,0"
                                     VerticalContentAlignment="Center"
                                     FontSize="12"/>
                            <Button Grid.Column="1"
                                    Content="Examinar"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="8,0,0,0"
                                    Padding="12,4" Height="32"
                                    Click="BrowseGDriveBtn_Click"/>
                        </Grid>

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ROW 2 — Separador ──────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{StaticResource BrushBorderSubtle}"/>

        <!-- ROW 3 — Botones ─────────────────────────────────────────────── -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="20,14,20,16">
            <Button x:Name="CancelBtn"
                    Content="Cancelar"
                    Style="{StaticResource SecondaryButton}"
                    Padding="14,7"
                    Margin="0,0,10,0"
                    Click="CancelBtn_Click"/>
            <Button x:Name="SaveBtn"
                    Content="Guardar"
                    Style="{StaticResource PrimaryButton}"
                    Padding="16,7"
                    Click="SaveBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
