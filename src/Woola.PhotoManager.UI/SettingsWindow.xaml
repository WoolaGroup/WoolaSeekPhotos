<Window x:Class="Woola.PhotoManager.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⚙️ Configuración" Width="520" Height="540"
        WindowStartupLocation="CenterOwner"
        Background="#0F0F0F" FontFamily="Segoe UI"
        ResizeMode="NoResize">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0" Text="⚙️ Configuración"
                   FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,20"/>

        <!-- Sección Agentes -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="AGENTES DE INDEXACIÓN"
                       FontSize="10" FontWeight="Bold" Foreground="#555555"
                       Margin="0,0,0,10"/>

            <Border Background="#1A1A1A" CornerRadius="8" Padding="4">
                <ScrollViewer MaxHeight="260" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="AgentsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="Transparent" Padding="12,8" CornerRadius="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsEnabled}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,12,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="White"/>
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="11" Foreground="#888888"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Sección Clustering Facial -->
            <TextBlock Text="CLUSTERING FACIAL"
                       FontSize="10" FontWeight="Bold" Foreground="#555555"
                       Margin="0,20,0,10"/>

            <Border Background="#1A1A1A" CornerRadius="8" Padding="16">
                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Umbral de similitud coseno"
                                   FontSize="13" Foreground="White" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" x:Name="ThresholdValueText"
                                   FontSize="14" FontWeight="Bold" Foreground="#0078D4"/>
                    </Grid>
                    <Slider x:Name="ThresholdSlider"
                            Minimum="0.50" Maximum="0.90" TickFrequency="0.05"
                            IsSnapToTickEnabled="True"
                            ValueChanged="ThresholdSlider_ValueChanged"
                            Foreground="#0078D4" Margin="0,4,0,0"/>
                    <Grid Margin="0,4,0,0">
                        <TextBlock Text="0.50 (más agrupado)" FontSize="10" Foreground="#666"
                                   HorizontalAlignment="Left"/>
                        <TextBlock Text="0.90 (más estricto)" FontSize="10" Foreground="#666"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Separador -->
        <Border Grid.Row="2" Height="1" Background="#333333" Margin="0,20,0,16"/>

        <!-- Botones -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelBtn" Content="Cancelar" Width="90" Height="34"
                    Background="#252525" Foreground="#888888"
                    BorderBrush="#333333" BorderThickness="1"
                    Margin="0,0,10,0" Cursor="Hand"
                    Click="CancelBtn_Click"/>
            <Button x:Name="SaveBtn" Content="💾 Guardar" Width="110" Height="34"
                    Background="#0078D4" Foreground="White" BorderThickness="0"
                    Cursor="Hand" Click="SaveBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
